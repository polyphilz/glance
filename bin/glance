#!/usr/bin/env bash
set -euo pipefail

read_version() {
  if [ -f "$GLANCE_ROOT/VERSION" ]; then
    tr -d '[:space:]' < "$GLANCE_ROOT/VERSION"
  else
    printf 'unknown'
  fi
}

usage() {
  cat <<'EOF'
glance - review git changes in a clean Neovim session

Usage:
  glance
  glance --help
  glance --version
  glance init-config [--force]

Commands:
  init-config  Write a starter config file to the default config path.

Requirements:
  - git on PATH
  - nvim 0.11+ on PATH

Notes:
  - Run glance inside a git repository.
  - Set GLANCE_CONFIG to load a config file from a custom path.
  - init-config uses GLANCE_CONFIG, then XDG_CONFIG_HOME, then ~/.config/glance/config.lua.
EOF
}

fail() {
  echo "glance: $*" >&2
  exit 1
}

info() {
  echo "glance: $*" >&2
}

require_command() {
  local command_name="$1"
  local message="$2"

  if ! command -v "$command_name" >/dev/null 2>&1; then
    fail "$message"
  fi
}

require_supported_nvim() {
  local first_line=""
  local parsed=""
  local major=""
  local minor=""
  local patch=""

  require_command "nvim" "nvim 0.11+ is required but was not found on PATH"

  first_line="$(nvim --version 2>/dev/null | sed -n '1p')"
  parsed="$(printf '%s\n' "$first_line" | sed -nE 's/^NVIM v([0-9]+)\.([0-9]+)(\.([0-9]+))?.*/\1 \2 \4/p')"

  if [ -z "$parsed" ]; then
    fail "failed to determine Neovim version from: ${first_line:-<empty output>}"
  fi

  IFS=' ' read -r major minor patch <<EOF
$parsed
EOF
  patch="${patch:-0}"

  if [ "$major" -eq 0 ] && [ "$minor" -lt 11 ]; then
    fail "nvim 0.11+ is required, found $major.$minor.$patch"
  fi
}

repo_has_changes() {
  local status_output=""

  status_output="$(git status --porcelain=v1 --untracked-files=all 2>/dev/null)" || return 1
  [ -n "$status_output" ]
}

config_path() {
  if [ -n "${GLANCE_CONFIG:-}" ]; then
    printf '%s\n' "$GLANCE_CONFIG"
  elif [ -n "${XDG_CONFIG_HOME:-}" ]; then
    printf '%s/glance/config.lua\n' "$XDG_CONFIG_HOME"
  else
    printf '%s/.config/glance/config.lua\n' "$HOME"
  fi
}

write_starter_config() {
  local path="$1"

  cat >"$path" <<'EOF'
return {
  theme = {
    preset = 'seti_black',
  },
  windows = {
    filetree = {
      width = 30,
    },
    diff = {
      relativenumber = true,
    },
  },
  minimap = {
    enabled = true,
    width = 1,
  },
  -- Hide the filetree legend if you want to reclaim a few rows.
  -- filetree = {
  --   show_legend = false,
  -- },
  -- Optional pane navigation aliases. Neovim's built-in <C-w> window
  -- commands still work without any config. If your terminal or tmux
  -- reports Ctrl-h/j/k/l as arrows, use the arrow-key tokens here.
  -- pane_navigation = {
  --   left = '<Left>',
  --   down = '<Down>',
  --   up = '<Up>',
  --   right = '<Right>',
  -- },
  -- Optional diff hunk navigation aliases.
  -- hunk_navigation = {
  --   next = 'n',
  --   prev = 'N',
  -- },
}
EOF
}

init_config() {
  local force="false"
  local path=""
  local dir=""

  case "${1:-}" in
    "")
      ;;
    --force)
      force="true"
      shift
      ;;
    *)
      fail "unknown option for init-config: $1"
      ;;
  esac

  if [ "$#" -gt 0 ]; then
    fail "unexpected arguments for init-config"
  fi

  path="$(config_path)"
  dir="$(dirname "$path")"
  mkdir -p "$dir"

  if [ -e "$path" ] && [ "$force" != "true" ]; then
    fail "config already exists at $path (use 'glance init-config --force' to overwrite)"
  fi

  write_starter_config "$path"
  info "wrote starter config to $path"
}

# Resolve symlinks to find the actual script location
SCRIPT="$0"
while [ -L "$SCRIPT" ]; do
  SCRIPT_DIR="$(cd "$(dirname "$SCRIPT")" && pwd)"
  SCRIPT="$(readlink "$SCRIPT")"
  [[ "$SCRIPT" != /* ]] && SCRIPT="$SCRIPT_DIR/$SCRIPT"
done
GLANCE_ROOT="$(cd "$(dirname "$SCRIPT")/.." && pwd)"
export GLANCE_ROOT

case "${1:-}" in
  -h|--help|help)
    usage
    exit 0
    ;;
  -v|--version|version)
    echo "glance $(read_version)"
    exit 0
    ;;
  init-config)
    shift
    init_config "$@"
    exit 0
    ;;
  "")
    ;;
  *)
    fail "unknown command or option: $1 (run 'glance --help')"
    ;;
esac

require_command "git" "git is required but was not found on PATH"

# Verify we're inside a git repository
if ! git rev-parse --is-inside-work-tree &>/dev/null; then
  fail "not a git repository"
fi

if ! repo_has_changes; then
  info "no changes found"
  exit 0
fi

require_supported_nvim

# Launch neovim in minimal mode with only the glance plugin
exec nvim --clean \
  --cmd "lua vim.opt.runtimepath:append(vim.env.GLANCE_ROOT)" \
  -c "lua require('glance.bootstrap').run()"
