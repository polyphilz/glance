#!/usr/bin/env bash
set -euo pipefail

# Resolve symlinks to find the actual script location
SCRIPT="$0"
while [ -L "$SCRIPT" ]; do
  SCRIPT_DIR="$(cd "$(dirname "$SCRIPT")" && pwd)"
  SCRIPT="$(readlink "$SCRIPT")"
  [[ "$SCRIPT" != /* ]] && SCRIPT="$SCRIPT_DIR/$SCRIPT"
done
GLANCE_ROOT="$(cd "$(dirname "$SCRIPT")/.." && pwd)"

# Verify we're inside a git repository
if ! git rev-parse --is-inside-work-tree &>/dev/null; then
  echo "glance: not a git repository" >&2
  exit 1
fi

# Launch neovim in minimal mode with only the glance plugin
# TODO: Move hunk_navigation into user-provided config once Glance has a real
# config entrypoint instead of hardcoding personal defaults in the launcher.
exec nvim --clean \
  --cmd "set rtp+=$GLANCE_ROOT" \
  -c "lua require('glance').setup({ hide_statusline = true, hunk_navigation = { next = 'n', prev = 'N' } })" \
  -c "Glance"
